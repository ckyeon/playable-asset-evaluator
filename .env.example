# Optional. Defaults to ~/Library/Application Support/asset-evaluator
ASSET_EVALUATOR_DATA_DIR=

# Optional. Defaults to mock. Use local-cli to run a subscription-backed Gemini/Codex CLI evaluator.
EVALUATION_ADAPTER=mock
EVALUATOR_PROVIDER=gemini
EVALUATOR_MODEL_NAME=
EVALUATOR_TIMEOUT_MS=120000

# Deprecated fallback for EVALUATOR_MODEL_NAME.
EVALUATION_MODEL=mock-evaluator-v1
